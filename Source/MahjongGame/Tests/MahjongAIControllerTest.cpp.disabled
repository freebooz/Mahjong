//==============================================================================
// MahjongAIController Unit Tests
// MahjongAIController 单元测试
//==============================================================================

#pragma once

#include "CoreMinimal.h"
#include "Gameplay/AI/MahjongAIController.h"
#include "GameFramework/Actor.h"
#include "Misc/AutomationTest.h"

#if WITH_DEV_AUTOMATION_TESTS

// 测试夹具类
class FMahjongAIControllerTestFixture
{
public:
    // 创建测试用手牌
    static TArray<int32> CreateStandardHand()
    {
        return {11, 12, 13, 21, 22, 23, 31, 32, 33, 41, 42, 43, 51};
    }

    static TArray<int32> CreateEmptyHand()
    {
        return {};
    }

    static TArray<int32> CreateSingleTileHand()
    {
        return {11};
    }

    static TArray<int32> CreateAllYaojiuHand()
    {
        return {11, 19, 21, 29, 31, 39};
    }

    static TArray<int32> CreateAllMiddleHand()
    {
        return {13, 14, 15, 23, 24, 25, 33, 34, 35};
    }
};

// 测试：策略层 - 进攻策略决策
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_StrategyDecision_HighTiles_UsesAggressive,
    "Mahjong.AI.Strategy.HighTiles_UsesAggressive",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_StrategyDecision_HighTiles_UsesAggressive::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 设置高剩余牌数（进攻策略）
    Controller->RemainingTiles = 100;

    // 执行策略决策
    Controller->MakeStrategyDecision();

    // 验证：牌多时应使用进攻策略
    TestEqual("High tiles should use aggressive strategy", Controller->bUseAggressiveStrategy, true);

    return true;
}

// 测试：策略层 - 防守策略决策
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_StrategyDecision_LowTiles_UsesDefensive,
    "Mahjong.AI.Strategy.LowTiles_UsesDefensive",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_StrategyDecision_LowTiles_UsesDefensive::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 设置低剩余牌数（防守策略）
    Controller->RemainingTiles = 30;

    // 执行策略决策
    Controller->MakeStrategyDecision();

    // 验证：牌少时应使用防守策略
    TestEqual("Low tiles should use defensive strategy", Controller->bUseAggressiveStrategy, false);

    return true;
}

// 测试：策略层 - 游戏局势评估
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_EvaluateGameSituation_ReturnsCorrectScore,
    "Mahjong.AI.Strategy.EvaluateGameSituation_ReturnsCorrectScore",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_EvaluateGameSituation_ReturnsCorrectScore::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 设置剩余牌数
    Controller->RemainingTiles = 72;  // 一半

    // 评估局势
    float Score = Controller->EvaluateGameSituation();

    // 验证：分数应该在0.5左右
    TestTrue("Score should be around 0.5", FMath::Abs(Score - 0.5f) < 0.01f);

    return true;
}

// 测试：动作层 - 碰牌评分
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_MakeActionDecision_CanPeng_ReturnsCorrectScore,
    "Mahjong.AI.Action.CanPeng_ReturnsCorrectScore",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_MakeActionDecision_CanPeng_ReturnsCorrectScore::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 手牌中有3张相同的牌
    TArray<int32> HandTiles = {11, 11, 11, 22, 23, 24, 25, 26, 27, 28, 29, 31, 32};
    int32 LastDiscardTile = 11;  // 可以碰

    // 执行动作决策
    FMahjongAIActionResult Result = Controller->MakeActionDecision(
        HandTiles, LastDiscardTile, true, false, false
    );

    // 验证：碰牌应该有较高分数
    TestTrue("Should be able to execute peng", Result.bCanExecute);

    return true;
}

// 测试：动作层 - 胡牌最高分
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_MakeActionDecision_CanHu_ReturnsHighestScore,
    "Mahjong.AI.Action.CanHu_ReturnsHighestScore",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_MakeActionDecision_CanHu_ReturnsHighestScore::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    TArray<int32> HandTiles = {11, 12, 13, 21, 22, 23, 31, 32, 33, 41, 42, 43, 51};
    int32 LastDiscardTile = 51;

    // 执行动作决策
    FMahjongAIActionResult Result = Controller->MakeActionDecision(
        HandTiles, LastDiscardTile, true, true, true  // 可以碰、杠、胡
    );

    // 验证：胡牌应该是最高分动作
    TestEqual("Hu should be selected when available", Result.SelectedAction, 3);

    return true;
}

// 测试：动作层 - 杠牌评分
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_ScoreGangAction_With4Tiles_ReturnsBestScore,
    "Mahjong.AI.Action.ScoreGang_With4Tiles_ReturnsBestScore",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_ScoreGangAction_With4Tiles_ReturnsBestScore::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 手牌中有4张相同的牌
    TArray<int32> HandTiles = {11, 11, 11, 11, 22, 23, 24, 25, 26, 27, 28, 29, 31};

    // 杠牌评分
    float Score = Controller->ScoreGangAction(HandTiles, 11);

    // 验证：4张牌应该是最高分
    TestEqual("4 tiles should have best gang score", Score, 100.0f);

    return true;
}

// 测试：出牌层 - 进攻性出牌选择高价值牌
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_MakeDiscardDecision_Aggressive_FindsHighValueTile,
    "Mahjong.AI.Discard.Aggressive_FindsHighValueTile",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_MakeDiscardDecision_Aggressive_FindsHighValueTile::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 混合手牌（既有中张也有幺九）
    TArray<int32> HandTiles = {11, 15, 25, 35, 45, 55, 65, 12, 22, 32, 42, 52, 62};

    // 执行出牌决策
    FMahjongAIDiscardResult Result = Controller->MakeDiscardDecision(HandTiles, false);

    // 验证：应该选择了中张之一（价值高）
    int32 SelectedTile = Result.SelectedTileIndex >= 0 ? HandTiles[Result.SelectedTileIndex] : -1;
    int32 Value = SelectedTile % 10;

    // 中张 3-7 价值高，应该优先保留
    TestTrue("Should select middle tile (value 3-7)",
        Value >= 3 && Value <= 7);

    return true;
}

// 测试：出牌层 - 危险性计算
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_CalculateTileDanger_SingleTile_ReturnsHighDanger,
    "Mahjong.AI.Discard.CalculateTileDanger_SingleTile_HighDanger",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_CalculateTileDanger_SingleTile_ReturnsHighDanger::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 手牌中只有1张11
    TArray<int32> HandTiles = {11};

    // 计算危险性
    float Danger = Controller->CalculateTileDanger(11, HandTiles);

    // 验证：单张应该有30分危险（单张危险）
    TestEqual("Single tile danger should be 30", Danger, 30.0f);

    return true;
}

// 测试：出牌层 - 幺九危险性计算
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_CalculateTileDanger_YaojiuTile_ReturnsHigherDanger,
    "Mahjong.AI.Discard.CalculateTileDanger_YaojiuTile_HigherDanger",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_CalculateTileDanger_YaojiuTile_ReturnsHigherDanger::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 手牌中幺九只有1张
    TArray<int32> HandTiles = {11, 12, 13};  // 11是幺九

    // 计算幺九危险性
    float Danger = Controller->CalculateTileDanger(11, HandTiles);

    // 验证：幺九+单张 = 20 + 30 = 50
    TestEqual("Yaojiu single tile danger should be 50", Danger, 50.0f);

    return true;
}

// 测试：出牌层 - 安全牌选择
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_FindSafeTileIndex_ReturnsMinDangerIndex,
    "Mahjong.AI.Discard.FindSafeTileIndex_ReturnsMinDanger",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_FindSafeTileIndex_ReturnsMinDangerIndex::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 手牌：1张幺九(11)，1张中张(15)
    TArray<int32> HandTiles = {11, 15};

    // 查找安全牌
    int32 SafeIndex = Controller->FindSafeTileIndex(HandTiles);

    // 验证：应该选择中张(15)，因为更安全
    TestEqual("Safe tile should be middle tile (15)", HandTiles[SafeIndex], 15);

    return true;
}

// 测试：听牌信息 - 有刻子可听
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_GetTingInfo_WithTriplet_ReturnsTingInfo,
    "Mahjong.AI.Ting.WithTriplet_ReturnsTingInfo",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_GetTingInfo_WithTriplet_ReturnsTingInfo::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 手牌有3张11（刻子）
    TArray<int32> HandTiles = {11, 11, 11, 22, 23, 24, 25, 26, 27, 28, 29, 31, 32};

    // 获取听牌信息
    FMahjongTingInfo TingInfo = Controller->GetTingInfo(HandTiles);

    // 验证：应该能听牌
    TestTrue("Should be in ting state", TingInfo.bIsTing);
    TestTrue("Ting count should be > 0", TingInfo.TingCount > 0);

    return true;
}

// 测试：听牌信息 - 无刻子不听
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_GetTingInfo_NoTriplet_ReturnsNotTing,
    "Mahjong.AI.Ting.NoTriplet_ReturnsNotTing",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_GetTingInfo_NoTriplet_ReturnsNotTing::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 手牌没有刻子
    TArray<int32> HandTiles = {11, 12, 13, 22, 23, 24, 25, 26, 27, 28, 29, 31, 32};

    // 获取听牌信息
    FMahjongTingInfo TingInfo = Controller->GetTingInfo(HandTiles);

    // 验证：不应该能听牌
    TestFalse("Should not be in ting state", TingInfo.bIsTing);
    TestEqual("Ting count should be 0", TingInfo.TingCount, 0);

    return true;
}

// 测试：出牌层 - 防守性出牌
IMPLEMENT_SIMPLE_AUTOMATION_TEST(
    FAITest_MakeDiscardDecision_Defensive,
    "Mahjong.AI.Discard.Defensive",
    EAutomationTestFlags::ApplicationContextMask | EAutomationTestFlags::ProductFilter
)

bool FAITest_MakeDiscardDecision_Defensive::RunTest(const FString& Parameters)
{
    AMahjongAIController* Controller = NewObject<AMahjongAIController>();
    if (!TestNotNull("Controller should exist", Controller))
    {
        return false;
    }

    // 设置为防守策略
    Controller->bUseAggressiveStrategy = false;

    // 手牌：既有危险牌也有安全牌
    TArray<int32> HandTiles = {11, 15, 25, 35, 45, 55, 65, 12, 22, 32, 42, 52, 62};

    // 执行出牌决策
    FMahjongAIDiscardResult Result = Controller->MakeDiscardDecision(HandTiles, false);

    // 验证：应该选择危险性低的牌
    TestTrue("Should select a valid tile", Result.SelectedTileIndex >= 0);

    return true;
}

#endif // WITH_DEV_AUTOMATION_TESTS
